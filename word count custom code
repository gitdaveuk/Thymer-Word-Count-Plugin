class Plugin extends AppPlugin {

    onLoad() {
        this.currentCounts = null;

        this.statusBarItem = this.ui.addStatusBarItem({
            icon: 'file-text',
            label: '0 words',
            tooltip: 'Word count — click for details',
            onClick: () => this.showDetailedStats()
        });

        this.commands = [
            this.ui.addCommandPaletteCommand({
                label: "Word Count: Refresh",
                icon: "refresh",
                onSelected: () => this.updateWordCount()
            }),
            this.ui.addCommandPaletteCommand({
                label: "Word Count: Show",
                icon: "file-text",
                onSelected: () => this.showDetailedStats()
            }),
        ];

        this.updateWordCount();
        this.updateInterval = setInterval(() => this.updateWordCount(), 1000);
    }

    onUnload() {
        clearInterval(this.updateInterval);
        this.statusBarItem?.remove();
        this.commands?.forEach(c => c.remove());
    }

    async updateWordCount() {
        const text = await this.getActiveText();
        this.currentCounts = this.countText(text);

        const { words, characters } = this.currentCounts;
        this.statusBarItem.setLabel(`${words} words`);
        this.statusBarItem.setTooltip(`Words: ${words}\nCharacters: ${characters}\nClick for details`);
    }

    async getActiveText() {
        try {
            const record = this.ui.getActivePanel()?.getActiveRecord();
            if (!record) return '';

            const lineItems = await record.getLineItems();

            return lineItems
                .map(item => this.segmentsToText(item.segments))
                .filter(Boolean)
                .join('\n');
        } catch (e) {
            console.error('[Word Count] Error getting text:', e);
            return '';
        }
    }

    segmentsToText(segments) {
        if (!segments?.length) return '';
        return segments
            .map(seg => typeof seg.text === 'string' ? seg.text : (seg.text?.title ?? ''))
            .join('');
    }

    countText(text) {
        if (!text?.trim()) {
            return { words: 0, characters: 0, charactersNoSpaces: 0, lines: 0 };
        }
        return {
            words: text.trim().split(/\s+/).filter(w => w.length > 0).length,
            characters: text.length,
            charactersNoSpaces: text.replace(/\s/g, '').length,
            lines: text.split('\n').length,
        };
    }

    showDetailedStats() {
        if (!this.currentCounts) return;
        const { words, characters, charactersNoSpaces, lines } = this.currentCounts;
        const reading = Math.ceil(words / 200);
        const speaking = Math.ceil(words / 150);

        this.ui.addToaster({
            title: "Document Statistics",
            message:
                `Words: ${words}\n` +
                `Characters: ${characters} (${charactersNoSpaces} no spaces)\n` +
                `Lines: ${lines}\n` +
                `Reading time: ~${reading} ${reading === 1 ? 'minute' : 'minutes'}\n` +
                `Speaking time: ~${speaking} ${speaking === 1 ? 'minute' : 'minutes'}`,
            dismissible: true,
            autoDestroyTime: 6000
        });
    }
}
